{
  "manifest_version": 3,
  "name": "JobTracker LinkedIn Saver",
  "description": "Añade un botón \"Guardar en JobTracker\" en ofertas de LinkedIn y las envía a tu JobTracker.",
  "version": "0.1.0",
  "permissions": [
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": ["content-linkedin.js"],
      "run_at": "document_idle"
    }
  ]
}

