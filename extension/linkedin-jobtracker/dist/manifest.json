{
  "manifest_version": 3,
  "name": "JobTracker LinkedIn Saver",
  "description": "Add a \"Save to JobTracker\" button on LinkedIn jobs and send them to your JobTracker account.",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://job-tracker-tool.vercel.app/*"
  ],
  "optional_host_permissions": [
    "http://localhost:3000/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": ["content-linkedin.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}

